node_modules/
*:Zone.Identifier
.DS_Store

# Python bytecode キャッシュ
__pycache__/

# ローカル専用デバッグスクリプト
scripts/debug/

# word-data の中間生成物・バックアップ（正マスターは word_data_final.json）
scripts/results/*.bk*
scripts/results/word_data_phase*.json

# 検証・生成スクリプトの出力レポート（再生成可能）
scripts/results/*.txt

# debug.html からエクスポートした localStorage state ダンプ（個人データ・持ち込み用）
*.json.gz

# 実機状態を使ったリアルモック用（個人データ）
app/_realstate.json

# デプロイ先（ホスト・ユーザー・パス）を含む実デプロイスクリプト。
# 公開しない接続先情報を含むため追跡しない（雛形は scripts/deploy_template.sh）
scripts/deploy.sh

# 開発・検証用モックページ／持ち込みページ（本番デプロイ対象外・個人データ経路）
app/_import.html
app/realmock.html
app/design-preview-wordwave.html
app/profile-mock.html
